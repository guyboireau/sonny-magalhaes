---
import { business, certifications } from '../config/site';
---

{/* ── A + C : Grille Classique ────────────────────────────────────────── */}
<section class="section section-alt cert-section v-only-a v-only-c" id="certifications">
  <div class="container">
    <div class="cert-head">
      <p class="eyebrow">{certifications.eyebrow}</p>
      <h2 class="cert-h2">{certifications.title}</h2>
      <p class="cert-sub">{certifications.subtitle}</p>
    </div>

    <div class="cert-a-grid">
      {business.certifications.map((cert) => (
        <div class="cert-a-card">
          <span class="cert-icon" aria-hidden="true">{cert.icon}</span>
          <h3 class="cert-label">{cert.label}</h3>
          <p class="cert-sublabel">{cert.sublabel}</p>
        </div>
      ))}

      <div class="cert-a-card cert-area">
        <span class="cert-icon" aria-hidden="true">📍</span>
        <h3 class="cert-label">Zone d'intervention</h3>
        <p class="cert-sublabel">{business.serviceArea.join(' · ')}</p>
      </div>

      <div class="cert-a-card">
        <span class="cert-icon" aria-hidden="true">📋</span>
        <h3 class="cert-label">Assurance RC Pro</h3>
        <p class="cert-sublabel">{business.assurance.name}</p>
      </div>

      <div class="cert-a-card">
        <span class="cert-icon" aria-hidden="true">🏢</span>
        <h3 class="cert-label">SIRET</h3>
        <p class="cert-sublabel">{business.siret}</p>
      </div>
    </div>
  </div>
</section>

{/* ── B : Minimaliste (Vercel Style) ─────────────────────────────────── */}
<section class="section section-alt v-only-b" id="certifications">
  <div class="container">
    <div class="cert-head">
      <p class="eyebrow">{certifications.eyebrow}</p>
      <h2 class="cert-h2">{certifications.title}</h2>
    </div>
    <div class="cert-b-list">
      {[...business.certifications, 
        { icon: '📍', label: "Zone d'intervention", sublabel: business.serviceArea.join(' · ') },
        { icon: '📋', label: "Assurance RC Pro", sublabel: business.assurance.name },
        { icon: '🏢', label: "SIRET", sublabel: business.siret }
      ].map((cert) => (
        <div class="cert-b-item">
          <span class="cert-b-icon">{cert.icon}</span>
          <div class="cert-b-content">
            <h3 class="cert-b-label">{cert.label}</h3>
            <p class="cert-b-sublabel">{cert.sublabel}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

{/* ── D : Forge — Brutaliste ─────────────────────────────────────────── */}
<section class="section v-only-d cert-d-section" id="certifications">
  <div class="container">
    <div class="cert-d-head">
      <p class="cert-d-eyebrow">{certifications.eyebrow}</p>
      <h2 class="cert-d-h2">{certifications.title}</h2>
    </div>
    <div class="cert-d-grid">
      {[...business.certifications, 
        { icon: '📍', label: "Zone", sublabel: business.serviceArea.join(' · ') },
        { icon: '📋', label: "RC Pro", sublabel: business.assurance.name },
        { icon: '🏢', label: "SIRET", sublabel: business.siret }
      ].map((cert) => (
        <div class="cert-d-card">
          <span class="cert-d-icon">{cert.icon}</span>
          <h3 class="cert-d-label">{cert.label}</h3>
          <p class="cert-d-sublabel">{cert.sublabel}</p>
        </div>
      ))}
    </div>
  </div>
</section>

{/* ── E : Le Salon — Éditorial ─────────────────────────────────────── */}
<section class="section v-only-e cert-e-section" id="certifications">
  <div class="container">
    <div class="cert-e-head">
      <p class="cert-e-eyebrow">{certifications.eyebrow}</p>
      <h2 class="cert-e-h2">{certifications.title}</h2>
      <p class="cert-e-sub">{certifications.subtitle}</p>
    </div>
    <div class="cert-e-list">
      {[...business.certifications, 
        { icon: '📍', label: "Secteur", sublabel: business.serviceArea.join(' · ') },
        { icon: '📋', label: "Assurance", sublabel: business.assurance.name },
        { icon: '🏢', label: "SIRET", sublabel: business.siret }
      ].map((cert) => (
        <div class="cert-e-item">
          <div class="cert-e-info">
            <h3 class="cert-e-label">{cert.label}</h3>
            <p class="cert-e-sublabel">{cert.sublabel}</p>
          </div>
          <span class="cert-e-icon">{cert.icon}</span>
        </div>
      ))}
    </div>
  </div>
</section>

{/* ── F : Stade — Tech ─────────────────────────────────────────────── */}
<section class="section section-alt v-only-f" id="certifications">
  <div class="container">
    <div class="cert-head">
      <p class="eyebrow">{certifications.eyebrow}</p>
      <h2 class="cert-h2">{certifications.title}</h2>
    </div>
    <div class="cert-f-grid">
      {[...business.certifications, 
        { icon: '📍', label: "Zone", sublabel: business.serviceArea.join(' · ') },
        { icon: '📋', label: "Assurance", sublabel: business.assurance.name },
        { icon: '🏢', label: "SIRET", sublabel: business.siret }
      ].map((cert) => (
        <div class="cert-f-card">
          <div class="cert-f-icon-wrap">{cert.icon}</div>
          <div class="cert-f-info">
            <h3 class="cert-f-label">{cert.label}</h3>
            <p class="cert-f-sublabel">{cert.sublabel}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

{/* ── G : Verveine — Wellness ──────────────────────────────────────── */}
<section class="section v-only-g cert-g-section" id="certifications">
  <div class="container">
    <div class="cert-head">
      <p class="eyebrow">{certifications.eyebrow}</p>
      <h2 class="cert-h2">{certifications.title}</h2>
    </div>
    <div class="cert-g-grid">
      {[...business.certifications, 
        { icon: '📍', label: "Zone d'intervention", sublabel: business.serviceArea.join(' · ') },
        { icon: '📋', label: "Assurance RC Pro", sublabel: business.assurance.name },
        { icon: '🏢', label: "SIRET", sublabel: business.siret }
      ].map((cert) => (
        <div class="cert-g-card">
          <span class="cert-g-icon">{cert.icon}</span>
          <h3 class="cert-g-label">{cert.label}</h3>
          <p class="cert-g-sublabel">{cert.sublabel}</p>
        </div>
      ))}
    </div>
  </div>
</section>

{/* ── H : ABPM — Corporate Clean ───────────────────────────────────── */}
<section class="section section-alt v-only-h cert-h-section" id="certifications">
  <div class="container">
    <div class="cert-h-head">
      <p class="cert-h-eyebrow">{certifications.eyebrow}</p>
      <h2 class="cert-h-h2">{certifications.title}</h2>
      <p class="cert-h-sub">{certifications.subtitle}</p>
    </div>
    <div class="cert-h-grid">
      {[...business.certifications, 
        { icon: '📍', label: "Zone d'intervention", sublabel: business.serviceArea.join(' · ') },
        { icon: '📋', label: "Assurance RC Pro", sublabel: business.assurance.name },
        { icon: '🏢', label: "SIRET", sublabel: business.siret }
      ].map((cert) => (
        <div class="cert-h-card">
          <div class="cert-h-top">
            <span class="cert-h-icon">{cert.icon}</span>
            <h3 class="cert-h-label">{cert.label}</h3>
          </div>
          <p class="cert-h-sublabel">{cert.sublabel}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
/* ─── Global / Head ─────────────────────────────────────────────────── */
.cert-head { text-align: center; margin-bottom: 52px; }
.cert-h2 {
  font-size: clamp(24px, 3vw, 36px); font-weight: 600;
  letter-spacing: -0.02em; color: var(--ink); margin: 12px 0 14px;
}
.cert-sub { font-size: 15px; color: var(--inkSoft); max-width: 52ch; margin: 0 auto; line-height: 1.6; }

/* ─── A / C ───────────────────────────────────────────────────────────── */
.cert-a-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 20px;
}
.cert-a-card {
  background: var(--bgCard);
  border: 1px solid var(--lineSoft);
  border-radius: var(--radius-lg);
  padding: 28px 24px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  transition: box-shadow 0.18s, transform 0.18s;
}
.cert-a-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
.cert-icon { font-size: 28px; line-height: 1; }
.cert-label { font-size: 15px; font-weight: 600; color: var(--ink); margin: 0; }
.cert-sublabel { font-size: 13px; color: var(--inkSoft); margin: 0; line-height: 1.45; }

/* ─── B : Minimaliste ────────────────────────────────────────────────── */
.cert-b-list { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
.cert-b-item { display: flex; gap: 16px; align-items: flex-start; }
.cert-b-icon { font-size: 24px; margin-top: 4px; }
.cert-b-label { font-size: 14px; font-weight: 600; color: var(--ink); margin-bottom: 4px; }
.cert-b-sublabel { font-size: 13px; color: var(--inkSoft); line-height: 1.5; }

/* ─── D : Forge Industrial ────────────────────────────────────────────── */
.cert-d-section { background: #dce3ea; }
.cert-d-head { margin-bottom: 40px; }
.cert-d-eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: #6a8099; }
.cert-d-h2 { font-family: 'Manrope', sans-serif; font-size: clamp(28px, 4vw, 42px); font-weight: 800; color: #1c2d45; margin: 8px 0 0; }
.cert-d-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
.cert-d-card {
  background: #e8ecf0; border: 2px solid #1c2d45; box-shadow: 4px 4px 0 #1c2d45;
  padding: 24px; display: flex; flex-direction: column; gap: 12px;
}
.cert-d-icon { font-size: 24px; }
.cert-d-label { font-family: 'Manrope', sans-serif; font-size: 16px; font-weight: 700; color: #1c2d45; margin: 0; }
.cert-d-sublabel { font-size: 13px; color: #4a6888; line-height: 1.4; }

/* ─── E : Le Salon Naval ──────────────────────────────────────────────── */
.cert-e-section { background: #f0f4f8; }
.cert-e-head { text-align: center; margin-bottom: 56px; }
.cert-e-eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: #6e88a8; }
.cert-e-h2 { font-family: 'Newsreader', Georgia, serif; font-size: clamp(28px, 4vw, 42px); font-style: italic; color: #1c3458; margin: 10px 0 16px; }
.cert-e-sub { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 15px; color: #3d5880; max-width: 50ch; margin: 0 auto; }
.cert-e-list { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
.cert-e-item { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #b8ccdd; padding-bottom: 20px; }
.cert-e-label { font-family: 'Newsreader', Georgia, serif; font-size: 18px; font-style: italic; color: #1c3458; margin-bottom: 4px; }
.cert-e-sublabel { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 13px; color: #3d5880; }
.cert-e-icon { font-size: 20px; opacity: 0.8; }

/* ─── F : Stade ────────────────────────────────────────────────────────── */
.cert-f-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.cert-f-card {
  background: #fff; border: 1px solid #e3e7ee; border-radius: 12px; padding: 24px;
  display: flex; gap: 16px; align-items: center;
}
.cert-f-icon-wrap { width: 44px; height: 44px; border-radius: 8px; background: #f8fafc; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; border: 1px solid #e2e8f0; }
.cert-f-label { font-size: 14px; font-weight: 600; color: #0a0e1a; margin-bottom: 2px; }
.cert-f-sublabel { font-size: 12px; color: #64748b; }

/* ─── G : Vague Aqua ──────────────────────────────────────────────────── */
.cert-g-section { background: #e8f4f8; }
.cert-g-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 24px; }
.cert-g-card {
  background: #f0f8fb; border: 1px solid #7ab8d0; border-radius: 24px;
  padding: 32px 24px; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 12px;
}
.cert-g-icon { font-size: 32px; }
.cert-g-label { font-family: 'DM Sans', sans-serif; font-size: 16px; font-weight: 600; color: #1c3d5a; margin: 0; }
.cert-g-sublabel { font-size: 13px; color: #2d5a7a; line-height: 1.5; }

/* ─── H : ABPM ────────────────────────────────────────────────────────── */
.cert-h-head { text-align: center; margin-bottom: 56px; }
.cert-h-eyebrow { font-family: 'Outfit', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: #0ea5e9; }
.cert-h-h2 { font-family: 'Outfit', sans-serif; font-size: clamp(28px, 4vw, 36px); font-weight: 700; color: #0f172a; margin: 10px 0 16px; }
.cert-h-sub { font-family: 'Outfit', sans-serif; font-size: 15px; color: #64748b; max-width: 52ch; margin: 0 auto; }
.cert-h-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
.cert-h-card {
  background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; padding: 24px;
  box-shadow: 0 1px 3px rgba(0,0,0,.04); transition: transform 0.2s, box-shadow 0.2s;
}
.cert-h-card:hover { transform: translateY(-2px); box-shadow: 0 4px 12px rgba(0,0,0,.08); }
.cert-h-top { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
.cert-h-icon { font-size: 20px; }
.cert-h-label { font-family: 'Outfit', sans-serif; font-size: 15px; font-weight: 600; color: #0f172a; margin: 0; }
.cert-h-sublabel { font-family: 'Outfit', sans-serif; font-size: 13px; color: #64748b; line-height: 1.5; }

/* ─── Responsive ──────────────────────────────────────────────────────── */
@media (max-width: 900px) {
  .cert-b-list, .cert-e-list, .cert-f-grid, .cert-h-grid { grid-template-columns: 1fr; gap: 20px; }
  .cert-a-grid { grid-template-columns: repeat(2, 1fr); }
  .cert-g-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 500px) {
  .cert-a-grid, .cert-g-grid { grid-template-columns: 1fr; }
}
</style>
