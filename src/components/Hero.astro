---
// Hero — 3 variantes
// A : Centré · eyebrow → H1 → sous-titre → 2 CTAs → trust strip
// B : Asymétrique · texte gauche (55%) + image droite + badge flottant
// C : Full-bleed éditorial · image plein cadre + H1 overlay + infos dessous
import { variants, hero, business } from '../config/site';

const v = variants.hero;
---

{/* ── Variante A : centré classique ──────────────────────────────────── */}
<section class="hero hero-a section v-only-a" id="hero-a">
  <div class="container hero-a-inner">
    <p class="eyebrow hero-eyebrow">{hero.eyebrow}</p>
    <h1 class="hero-a-h1">{hero.h1}</h1>
    <p class="hero-a-sub">{hero.subtitle}</p>
    <div class="hero-a-actions">
      <a href={hero.cta1.href} class="btn btn-primary btn-lg">{hero.cta1.label}</a>
      <a href={hero.cta2.href} class="btn btn-outline btn-lg">{hero.cta2.label}</a>
    </div>
    <div class="trust-strip">
      <p class="eyebrow trust-label">Ils nous font confiance</p>
      <div class="trust-items">
        {hero.trust.map(t => (
          <span class="trust-item">{t}</span>
        ))}
      </div>
    </div>
    {hero.image && (
      <div class="hero-a-img-wrap">
        <img src={hero.image} class="hero-a-img" alt={hero.h1} loading="lazy" />
      </div>
    )}
  </div>
</section>

{/* ── Variante B : asymétrique texte + image ─────────────────────────── */}
<section class="hero hero-b section v-only-b" id="hero-b">
  <div class="container hero-b-inner">
    <div class="hero-b-text">
      <p class="eyebrow hero-eyebrow">{hero.eyebrow}</p>
      <h1 class="hero-b-h1">{hero.h1}</h1>
      <p class="hero-b-sub">{hero.subtitle}</p>
      <div class="hero-b-actions">
        <a href={hero.cta1.href} class="btn btn-primary btn-lg">{hero.cta1.label}</a>
        <a href={hero.cta2.href} class="btn btn-outline btn-lg">{hero.cta2.label}</a>
      </div>
      <div class="hero-b-meta">
        <div class="hero-b-divider"></div>
        <div class="hero-b-author">
          <span class="author-avatar" aria-hidden="true"></span>
          <div>
            <p class="author-name">{hero.badge.label}</p>
            <p class="author-sub eyebrow">{hero.badge.sub}</p>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-b-visual">
      <img src={hero.image} class="hero-b-img" alt={hero.h1} />
      <div class="hero-b-badge">
        <p class="badge-label eyebrow">{hero.badge.label}</p>
        <p class="badge-value">{hero.badge.value}</p>
        <div class="stars" aria-label="5 étoiles">
          {'★★★★★'.split('').map(s => <span class="star">{s}</span>)}
        </div>
      </div>
    </div>
  </div>
</section>

{/* ── Variante C : full-bleed éditorial ─────────────────────────────── */}
  <section class="hero hero-c v-only-c" id="hero-c">
    <div class="hero-c-visual">
      <img src={hero.image} class="hero-c-bg-img" alt="" />
      <div class="hero-c-overlay"></div>
    <div class="hero-c-eyebrow-wrap">
      <p class="eyebrow hero-c-eyebrow-pill">{hero.eyebrow}</p>
    </div>
    <div class="hero-c-h1-wrap">
      <h1 class="hero-c-h1">{hero.h1}</h1>
    </div>
  </div>
  <div class="hero-c-below section">
    <div class="container hero-c-below-inner">
      <div class="hero-c-text">
        <p class="hero-c-sub">{hero.subtitle}</p>
        <div class="hero-c-actions">
          <a href={hero.cta1.href} class="btn btn-primary btn-lg">{hero.cta1.label}</a>
          <a href={hero.cta2.href} class="btn btn-outline btn-lg">{hero.cta2.label}</a>
        </div>
      </div>
      <div class="hero-c-infocard">
        <p class="eyebrow" style="color: var(--inkFaint)">{hero.infoCard.status}</p>
        <p class="infocard-hours">{hero.infoCard.hours}</p>
        <p class="infocard-location text-muted">{hero.infoCard.location}</p>
      </div>
    </div>
  </div>
</section>

{/* ── Variante E : Le Salon — Éditorial Serif ─────────────────────────── */}
<section class="hero-e v-only-e" id="hero-e">
  <div class="hero-e-inner">
    <div class="hero-e-eyebrow">
      <span class="hero-e-rule"></span>
      <span class="hero-e-eyebrow-text">{hero.eyebrow}</span>
      <span class="hero-e-rule"></span>
    </div>
    <h1 class="hero-e-h1">{hero.h1.split(' ').slice(0,3).join(' ')} <em>{hero.h1.split(' ').slice(3).join(' ')}</em></h1>
    <p class="hero-e-sub">{hero.subtitle}</p>
    <div class="hero-e-actions">
      <a href={hero.cta1.href} class="hero-e-btn-primary">{hero.cta1.label}</a>
      <a href={hero.cta2.href} class="hero-e-btn-ghost">{hero.cta2.label} →</a>
    </div>
  </div>
  <div class="hero-e-img-wrap">
    <img src={hero.image} class="hero-e-img" alt={hero.h1} />
  </div>
</section>

{/* ── Variante F : Stade — Tech BtoB ───────────────────────────────────── */}
<section class="hero-f v-only-f" id="hero-f">
  <div class="container hero-f-inner">
    <div class="hero-f-text">
      <div class="hero-f-badge">
        <span class="hero-f-badge-dot" aria-hidden="true"></span>
        <span>{hero.badge.sub}</span>
      </div>
      <h1 class="hero-f-h1">{hero.h1}</h1>
      <p class="hero-f-sub">{hero.subtitle}</p>
      <div class="hero-f-actions">
        <a href={hero.cta1.href} class="hero-f-btn-primary">{hero.cta1.label} →</a>
        <a href={hero.cta2.href} class="hero-f-btn-secondary">{hero.cta2.label}</a>
      </div>
      <div class="hero-f-trust">
        {hero.trust.map((t: string) => <span class="hero-f-trust-item">✓ {t}</span>)}
      </div>
    </div>
    <div class="hero-f-visual">
      <div class="hero-f-img-frame">
        <img src={hero.image} class="hero-f-img" alt={hero.h1} loading="lazy" />
      </div>
    </div>
  </div>
</section>

{/* ── Variante G : Verveine — Wellness Soft ──────────────────────────────── */}
<section class="hero-g v-only-g" id="hero-g">
  <div class="hero-g-blobs" aria-hidden="true">
    <div class="hero-g-blob hero-g-blob-1"></div>
    <div class="hero-g-blob hero-g-blob-2"></div>
  </div>
  <div class="hero-g-inner">
    <div class="hero-g-badge">
      <span class="hero-g-badge-dot" aria-hidden="true"></span>
      <span>{hero.badge.sub}</span>
    </div>
    <h1 class="hero-g-h1">{hero.h1}</h1>
    <p class="hero-g-sub">{hero.subtitle}</p>
    <div class="hero-g-actions">
      <a href={hero.cta1.href} class="hero-g-btn-primary">{hero.cta1.label}</a>
      <a href={hero.cta2.href} class="hero-g-btn-secondary">{hero.cta2.label} →</a>
    </div>
  </div>
  <div class="hero-g-img-wrap">
    <img src={hero.image} class="hero-g-img" alt={hero.h1} />
  </div>
</section>

{/* ── Variante D : Forge / Brutalist Warm ─────────────────────────────── */}
<section class="hero-d v-only-d" id="hero-d">
  {/* Stamps bar */}
  <div class="hero-d-stamps">
    <span class="hero-d-stamp-text">{hero.eyebrow.toUpperCase()}</span>
    <span class="hero-d-dot" aria-hidden="true"></span>
    <span class="hero-d-stamp-text">{business.address.city.toUpperCase()}</span>
    <span class="hero-d-dot" aria-hidden="true"></span>
    <span class="hero-d-stamp-text">FAIT MAIN · FRANCE</span>
    <span class="hero-d-scroll">↘ DÉFILER</span>
  </div>

  {/* Main hero */}
  <div class="container hero-d-main">
    <div class="hero-d-left">
      <span class="hero-d-stamp-label">N°01 — L'ATELIER</span>
      <h1 class="hero-d-h1">{hero.h1}</h1>
    </div>
    <div class="hero-d-infocard">
      <div class="hero-d-card-tag">▼ ACTU</div>
      <div class="hero-d-card-val">{hero.badge.value}</div>
      <div class="hero-d-card-lbl">{hero.badge.label}</div>
      <div class="hero-d-card-sub">{hero.badge.sub}</div>
    </div>
  </div>

  {/* Subtitle + CTAs */}
  <div class="container hero-d-below">
    <p class="hero-d-sub">{hero.subtitle}</p>
    <div class="hero-d-actions">
      <a href={hero.cta1.href} class="hero-d-btn-primary">{hero.cta1.label} →</a>
      <a href={hero.cta2.href} class="hero-d-btn-secondary">{hero.cta2.label}</a>
    </div>
  </div>

  {/* Trust strip */}
  <div class="hero-d-trust">
    {hero.trust.map((t: string) => (
      <span class="hero-d-trust-item">— {t.toUpperCase()}</span>
    ))}
  </div>
</section>
 
{/* ── Variante H : Artisan — Style ABPM Richard ─────────────────────────── */}
<section class="hero-h v-only-h" id="hero-h">
  <div class="container hero-h-container">
    <div class="hero-h-content">
      <span class="hero-h-badge">Professionnel & Qualité Supérieure</span>
      <h1>{hero.h1}</h1>
      <p>{hero.subtitle}</p>
      <div class="hero-h-actions">
        <a href={hero.cta1.href} class="btn btn-primary">
          {hero.cta1.label} <i class="ph ph-arrow-right"></i>
        </a>
        <a href={hero.cta2.href} class="btn btn-secondary">
          {hero.cta2.label}
        </a>
      </div>
      <div class="hero-h-features">
        {hero.trust.map((t: string) => (
          <div class="hero-h-feature"><i class="ph-fill ph-check-circle"></i> {t}</div>
        ))}
      </div>
    </div>
  </div>
  <div class="hero-h-bg" style={`background-image: linear-gradient(to right, #0f172a 20%, rgba(15, 23, 42, 0.2) 100%), url(${hero.image})`}></div>
</section>

<style>
/* ─── Commun ────────────────────────────────────────────────────────────── */
.hero-eyebrow { margin-bottom: 20px; }

/* ─── Variante A ─────────────────────────────────────────────────────────── */
.hero-a {
  padding-top: calc(68px + clamp(80px, 12vw, 160px));
  padding-bottom: clamp(60px, 10vw, 120px);
  background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 50%, #3b82f6 100%);
  color: #fff;
  text-align: center;
}
.hero-a-inner {
  display: flex; flex-direction: column; align-items: center;
  text-align: center;
  max-width: 760px; margin: 0 auto;
}
.hero-a-h1 {
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 600;
  letter-spacing: -0.03em;
  line-height: 1.05;
  color: #fff;
  margin-bottom: 24px;
}
.hero-a-sub {
  font-size: clamp(16px, 2vw, 19px);
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
  max-width: 56ch;
  margin-bottom: 40px;
}
.hero-a-actions {
  display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;
  margin-bottom: 72px;
}
.hero-a-actions .btn-primary {
  background: #fff;
  color: #0266FF;
  border-radius: 12px;
  font-weight: 700;
  padding: 1rem 2.5rem;
  box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.2);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.hero-a-actions .btn-primary:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.2);
}
.hero-a-actions .btn-outline {
  border: 1px solid rgba(255, 255, 255, 0.4);
  color: #fff;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  padding: 1rem 2.5rem;
  backdrop-filter: blur(4px);
}
.trust-strip {
  width: 100%;
  border-top: 1px solid rgba(255, 255, 255, 0.15);
  padding-top: 32px;
  display: flex; flex-direction: column; align-items: center; gap: 16px;
}
.trust-label { margin: 0; color: rgba(255, 255, 255, 0.7); }
.trust-items {
  display: flex; flex-wrap: wrap; justify-content: center; gap: 8px 24px;
}
.trust-item {
  font-size: 13px; color: rgba(255, 255, 255, 0.6); font-family: var(--fontMono);
}
.trust-item::before { content: '✓  '; color: #fff; }

/* Hero A — image optionnelle sous le trust strip */
.hero-a-img-wrap {
  width: 100%; max-width: 960px;
  margin: 56px auto 0;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}
.hero-a-img {
  width: 100%; max-height: 500px;
  object-fit: cover; display: block;
}

/* ─── Variante B ─────────────────────────────────────────────────────────── */
.hero-b { padding-top: calc(68px + clamp(40px, 8vw, 80px)); }
.hero-b-inner {
  display: grid;
  grid-template-columns: 55fr 45fr;
  gap: clamp(40px, 6vw, 80px);
  align-items: center;
}
.hero-b-h1 {
  font-size: clamp(32px, 4.5vw, 58px);
  font-weight: 600; letter-spacing: -0.03em; line-height: 1.06;
  color: var(--ink); margin-bottom: 24px;
}
.hero-b-sub {
  font-size: clamp(15px, 1.8vw, 18px);
  color: var(--inkSoft); line-height: 1.65;
  max-width: 52ch; margin-bottom: 36px;
}
.hero-b-actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 40px; }
.hero-b-divider { height: 1px; background: var(--lineSoft); margin-bottom: 20px; }
.hero-b-author { display: flex; align-items: center; gap: 14px; }
.author-avatar {
  width: 40px; height: 40px; border-radius: 50%;
  background: var(--lineSoft);
  flex-shrink: 0;
}
.author-name { font-size: 14px; font-weight: 500; color: var(--ink); margin-bottom: 2px; }
.author-sub { margin: 0; }

/* Image */
.hero-b-visual { position: relative; }
.hero-b-img {
  width: 100%;
  aspect-ratio: 4/5;
  object-fit: cover;
  border-radius: var(--radius-lg);
}
.hero-b-badge {
  position: absolute; bottom: -20px; left: -20px;
  background: var(--bgCard);
  border: 1px solid var(--lineSoft);
  border-radius: var(--radius-md);
  padding: 16px 20px;
  box-shadow: var(--shadow-md);
  min-width: 160px;
}
.badge-label { margin-bottom: 4px; }
.badge-value {
  font-size: 28px; font-weight: 600; color: var(--ink);
  letter-spacing: -0.02em; margin-bottom: 4px;
}

/* ─── Variante C ─────────────────────────────────────────────────────────── */
.hero-c-visual {
  position: relative;
  width: 100%;
  aspect-ratio: 16/7;
  min-height: 400px;
  border-radius: 0;
  overflow: hidden;
}
.hero-c-bg-img {
  position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
}
.hero-c-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,.55) 0%, rgba(0,0,0,.0) 50%);
}
.hero-c-eyebrow-wrap {
  position: absolute; top: 28px; left: clamp(24px, 5vw, 60px);
}
.hero-c-eyebrow-pill {
  background: rgba(255,255,255,.88);
  backdrop-filter: blur(8px);
  padding: 6px 14px; border-radius: 100px;
  color: var(--ink); margin: 0;
}
.hero-c-h1-wrap {
  position: absolute; bottom: 36px; left: clamp(24px, 5vw, 60px);
  right: clamp(24px, 5vw, 60px);
}
.hero-c-h1 {
  font-size: clamp(28px, 5vw, 56px);
  font-weight: 600; letter-spacing: -0.03em; line-height: 1.08;
  color: #fff;
}
.hero-c-below { padding: clamp(36px, 5vw, 64px) 0; }
.hero-c-below-inner {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 48px; align-items: start;
}
.hero-c-sub {
  font-size: clamp(15px, 1.8vw, 18px); color: var(--inkSoft);
  line-height: 1.65; margin-bottom: 28px; max-width: 60ch;
}
.hero-c-actions { display: flex; gap: 12px; flex-wrap: wrap; }
.hero-c-infocard {
  background: var(--bgCard);
  border: 1px solid var(--lineSoft);
  border-radius: var(--radius-md);
  padding: 20px 24px;
  min-width: 200px;
  flex-shrink: 0;
}
.infocard-hours {
  font-size: 15px; font-weight: 600; color: var(--ink);
  margin: 6px 0 4px;
}
.infocard-location { font-size: 13px; }

/* ─── Responsive ─────────────────────────────────────────────────────────── */
@media (max-width: 900px) {
  .hero-b-inner { grid-template-columns: 1fr; }
  .hero-b-visual { display: none; }
  .hero-c-below-inner { grid-template-columns: 1fr; }
  .hero-c-infocard { max-width: 100%; }
}
@media (max-width: 600px) {
  .hero-a-actions, .hero-b-actions, .hero-c-actions {
    flex-direction: column;
  }
  .hero-a-actions .btn, .hero-b-actions .btn, .hero-c-actions .btn {
    width: 100%; justify-content: center;
  }
}

/* ─── Variante E : Le Salon — Naval Premium ──────────────────────────── */
.hero-e {
  padding-top: 68px;
  background: #f0f4f8;
  display: grid; grid-template-columns: 1fr 1fr;
  min-height: 90vh;
}
.hero-e-inner {
  display: flex; flex-direction: column; justify-content: center;
  padding: clamp(48px, 8vw, 96px) clamp(32px, 5vw, 64px);
  text-align: center; align-items: center;
}
.hero-e-eyebrow {
  display: inline-flex; align-items: center; gap: 14px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; color: #6e88a8;
  letter-spacing: 0.25em; text-transform: uppercase;
  margin-bottom: 28px;
}
.hero-e-rule { width: 36px; height: 1px; background: #1c3458; }
.hero-e-eyebrow-text { white-space: nowrap; }
.hero-e-h1 {
  font-family: 'Newsreader', Georgia, serif;
  font-weight: 400; font-size: clamp(48px, 6vw, 96px);
  line-height: 0.98; letter-spacing: -0.025em;
  color: #1c3458; margin: 0 0 24px;
}
.hero-e-h1 em { font-style: italic; color: #2d6ac4; }
.hero-e-sub {
  font-family: 'Plus Jakarta Sans', sans-serif;
  font-size: 18px; color: #3d5880; max-width: 52ch;
  line-height: 1.55; margin: 0 0 40px;
}
.hero-e-actions { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }
.hero-e-btn-primary {
  font-family: 'Plus Jakarta Sans', sans-serif; font-size: 14px;
  padding: 14px 26px; background: #1c3458; color: #f8fafc;
  border: 1px solid #1c3458; border-radius: 0; text-decoration: none;
  transition: background 0.15s;
}
.hero-e-btn-primary:hover { background: #2d6ac4; border-color: #2d6ac4; }
.hero-e-btn-primary:focus-visible, .hero-e-btn-ghost:focus-visible { outline: 2px solid #1c3458; outline-offset: 3px; }
.hero-e-btn-ghost {
  font-family: 'Plus Jakarta Sans', sans-serif; font-size: 14px;
  padding: 14px 26px; background: transparent; color: #1c3458;
  border: 1px solid #1c3458; border-radius: 0; text-decoration: none;
}
.hero-e-img-wrap { overflow: hidden; }
.hero-e-img { width: 100%; height: 100%; object-fit: cover; }
@media (max-width: 900px) {
  .hero-e { grid-template-columns: 1fr; min-height: auto; }
  .hero-e-img-wrap { height: 320px; }
}

/* ─── Variante F : Stade ─────────────────────────────────────────────── */
.hero-f {
  padding-top: 56px;
  background-image: radial-gradient(#e3e7ee 1px, transparent 1px);
  background-size: 24px 24px;
  background-color: #fafbfc;
  border-bottom: 1px solid #e3e7ee;
  padding-bottom: clamp(48px, 8vw, 80px);
}
.hero-f-inner {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 64px; align-items: center;
  padding-top: 80px;
}
.hero-f-badge {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 5px 12px;
  border: 1px solid #e3e7ee; border-radius: 999px;
  background: #fff;
  font-family: 'Geist Mono', monospace; font-size: 11px; color: #3d4458;
  margin-bottom: 28px;
}
.hero-f-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #0f9a6e; }
.hero-f-h1 {
  font-family: 'Geist', sans-serif; font-weight: 600;
  font-size: clamp(40px, 5vw, 68px);
  line-height: 1.02; letter-spacing: -0.035em;
  color: #0a0e1a; margin: 0 0 24px;
}
.hero-f-sub {
  font-family: 'Geist', sans-serif;
  font-size: 18px; color: #3d4458; max-width: 48ch;
  line-height: 1.55; margin: 0 0 32px;
}
.hero-f-actions { display: flex; gap: 10px; margin-bottom: 36px; flex-wrap: wrap; }
.hero-f-btn-primary {
  font-family: 'Geist', sans-serif; font-weight: 500; font-size: 14px;
  padding: 12px 20px; background: #0a0e1a; color: #fff;
  border: 1px solid #0a0e1a; border-radius: 8px; text-decoration: none;
  transition: background 0.15s;
}
.hero-f-btn-primary:hover { background: #3a63ff; border-color: #3a63ff; }
.hero-f-btn-primary:focus-visible, .hero-f-btn-secondary:focus-visible { outline: 2px solid #0a0e1a; outline-offset: 3px; }
.hero-f-btn-secondary {
  font-family: 'Geist', sans-serif; font-weight: 500; font-size: 14px;
  padding: 12px 20px; background: #fff; color: #0a0e1a;
  border: 1px solid #e3e7ee; border-radius: 8px; text-decoration: none;
}
.hero-f-trust {
