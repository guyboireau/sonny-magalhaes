---
import { business } from '../config/site';

const { urgency } = business;
const phone = urgency.phone.replace(/\s/g, '');
---

{urgency.active && (
  <a
    href={`tel:${phone}`}
    class="urgent-float"
    aria-label={`${urgency.label} — appeler ${urgency.phone}`}
  >
    <span class="urgent-pulse" aria-hidden="true"></span>
    <svg class="urgent-icon" width="22" height="22" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
         aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.94h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.02z"/>
    </svg>
    <span class="urgent-label">{urgency.label}</span>
  </a>
)}

<style>
.urgent-float {
  position: fixed;
  bottom: 28px;
  right: 24px;
  z-index: 500;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 20px 14px 16px;
  background: #dc2626;
  color: #fff;
  border-radius: 9999px;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  box-shadow: 0 4px 20px rgba(220, 38, 38, 0.4);
  transition: transform 0.2s, box-shadow 0.2s;
}
.urgent-float:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(220, 38, 38, 0.5);
}
.urgent-float:focus-visible {
  outline: 3px solid #dc2626;
  outline-offset: 3px;
}
.urgent-pulse {
  position: absolute;
  inset: 0;
  border-radius: 9999px;
  border: 2px solid #dc2626;
  animation: urgent-ring 2s ease-out infinite;
}
@keyframes urgent-ring {
  0%   { transform: scale(1);   opacity: 0.7; }
  100% { transform: scale(1.3); opacity: 0; }
}
.urgent-icon { flex-shrink: 0; }
.urgent-label { white-space: nowrap; letter-spacing: 0.01em; }

@media (max-width: 600px) {
  .urgent-float { padding: 16px; }
  .urgent-label { display: none; }
}
</style>
